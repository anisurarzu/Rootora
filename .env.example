# Database
DATABASE_URL="postgresql://rootora:rootora@localhost:5433/rootora?schema=public"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Better Auth (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Google OAuth
# 1) Create OAuth Client at: https://console.cloud.google.com/apis/credentials
# 2) Application type: Web application
# 3) Authorized JavaScript origins:
#      http://localhost:3000
#      https://shoprootora.com
# 4) Authorized redirect URIs:
#      http://localhost:3000/api/auth/callback/google
#      https://shoprootora.com/api/auth/callback/google
#      https://www.shoprootora.com/api/auth/callback/google
# 5) Paste Client ID + Client Secret below
# 6) Set NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true
# 7) Restart the server
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED="false"

# Mobile / API
# Optional CORS origin for React Native / Expo web / Flutter web
MOBILE_CORS_ORIGIN="*"

# Resend (optional)
RESEND_API_KEY=""

# Payments (optional)
SSLCOMMERZ_STORE_ID=""
SSLCOMMERZ_STORE_PASSWORD=""
SSLCOMMERZ_IS_LIVE="false"
BKASH_APP_KEY=""
BKASH_APP_SECRET=""
BKASH_USERNAME=""
BKASH_PASSWORD=""
BKASH_IS_SANDBOX="true"
NAGAD_MERCHANT_ID=""
NAGAD_MERCHANT_NUMBER=""
NAGAD_PUBLIC_KEY=""
NAGAD_PRIVATE_KEY=""
NAGAD_IS_SANDBOX="true"
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
